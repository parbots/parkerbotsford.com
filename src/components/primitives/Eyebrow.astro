---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<span class:list={["eyebrow", className]}>
  <slot />
</span>

<style>
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .eyebrow::before {
    content: "";
    display: inline-block;
    height: 1px;
    width: 1rem;
    background: var(--accent);
  }
</style>
